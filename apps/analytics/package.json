{
  "name": "@modulus/analytics",
  "version": "0.0.1",
  "private": true,
  "description": "Modulus analytics micro-frontend",
  "scripts": {
    "dev": "webpack serve --config webpack.config.ts --mode development --port 3003",
    "build": "webpack --config webpack.config.ts --mode production",
    "typecheck": "npx tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "clean": "rm -rf dist"
